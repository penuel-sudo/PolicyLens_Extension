{
  "manifest_version": 3,
  "name": "PolicyLens",
  "version": "1.0.0",
  "description": "Instant privacy policy risk analysis for every site you visit.",
  "icons": {
    "16":  "favicon_io/favicon-16x16.png",
    "32":  "favicon_io/favicon-32x32.png",
    "48":  "favicon_io/favicon-32x32.png",
    "128": "favicon_io/android-chrome-192x192.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "favicon_io/favicon-16x16.png",
      "32":  "favicon_io/favicon-32x32.png",
      "48":  "favicon_io/favicon-32x32.png",
      "128": "favicon_io/android-chrome-192x192.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "popup.js",
        "floating-popup.html",
        "floating-popup.js",
        "assets/*",
        "favicon_io/favicon-16x16.png",
        "favicon_io/favicon-32x32.png",
        "favicon_io/android-chrome-192x192.png",
        "favicon_io/apple-touch-icon.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src 'self' https://policy-lens-extension.vercel.app https://policylens-production.up.railway.app https://duckduckgo.com https://*.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; script-src 'self'"
  }
}
